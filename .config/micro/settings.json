{
    "autoclose": true,
    "autoindent": true,
    "autosave": 2,
    "backup": true,
    "backupdir": "~/.config/micro/backups",
    "colorcolumn": 80,
    "colorscheme": "monokai",
    "cursorline": true,
    "diffgutter": true,
    "encoding": "utf-8",
    "eofnewline": true,
    "fileformat": "unix",
    "hlsearch": true,
    "ignorecase": true,
    "indentchar": " ",
    "infobar": true,
    "linter": true,
    "matchbrace": true,
    "mouse": true,
    "rmtrailingws": true,
    "ruler": true,
    "savehistory": true,
    "scrollmargin": 3,
    "scrollspeed": 2,
    "smartpaste": true,
    "softwrap": false,
    "splitbottom": true,
    "splitright": true,
    "statusline": true,
    "syntax": true,
    "tabsize": 4,
    "tabstospaces": true,
    "wordwrap": false
}