# Mako notification daemon configuration

# Appearance
font=Quicksand Medium 12
background-color=#17130bee
text-color=#ebe1d4
border-color=#d9c4a0
border-size=2
border-radius=10
padding=15
margin=10

# Position and size
anchor=top-right
width=350
height=100
max-visible=5

# Behavior
default-timeout=5000
ignore-timeout=0
group-by=app-name

# Icons
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Papirus-Dark

# Progress bar
progress-color=over #b1cfa8

# Urgency levels
[urgency=low]
background-color=#17130bcc
border-color=#ebc16c
default-timeout=3000

[urgency=normal]
background-color=#17130bee
border-color=#d9c4a0
default-timeout=5000

[urgency=critical]
background-color=#ffb4abee
border-color=#ffb4ab
text-color=#690005
default-timeout=0

# App-specific styling
[app-name=volume]
border-color=#ebc16c
background-color=#ebc16caa

[app-name=brightness]
border-color=#b1cfa8
background-color=#b1cfa8aa

[app-name=battery]
border-color=#b1cfa8
background-color=#b1cfa8aa

[app-name=network]
border-color=#d9c4a0
background-color=#d9c4a0aa

[app-name=spotify]
border-color=#1db954
background-color=#191414ee
default-timeout=4000

[app-name=Spotify]
border-color=#1db954
background-color=#191414ee
default-timeout=4000